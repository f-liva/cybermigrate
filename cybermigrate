# :command.parse_requirements
cybermigrate_migrate_parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        cybermigrate_migrate_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="migrate"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --package | -p)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--package']="$2"
          shift
          shift
        else
          printf "%s\n" "--package requires an argument: --package, -p PACKAGE" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --owner | -o)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--owner']="$2"
          shift
          shift
        else
          printf "%s\n" "--owner requires an argument: --owner, -o OWNER" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --php)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--php']="$2"
          shift
          shift
        else
          printf "%s\n" "--php requires an argument: --php PHP" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --skip-files)

        # :flag.case_no_arg
        args['--skip-files']=1
        shift
        ;;

      # :flag.case
      --skip-db)

        # :flag.case_no_arg
        args['--skip-db']=1
        shift
        ;;

      # :flag.case
      --skip-ssl)

        # :flag.case_no_arg
        args['--skip-ssl']=1
        shift
        ;;

      # :flag.case
      --dry-run)

        # :flag.case_no_arg
        args['--dry-run']=1
        shift
        ;;

      # :flag.case
      --git-repo | -g)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--git-repo']="$2"
          shift
          shift
        else
          printf "%s\n" "--git-repo requires an argument: --git-repo, -g REPO" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --git-branch)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--git-branch']="$2"
          shift
          shift
        else
          printf "%s\n" "--git-branch requires an argument: --git-branch BRANCH" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --deploy-script | -d)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--deploy-script']="$2"
          shift
          shift
        else
          printf "%s\n" "--deploy-script requires an argument: --deploy-script, -d SCRIPT" >&2
          exit 1
        fi
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        # :argument.case
        if [[ -z ${args['domain']+x} ]]; then
          args['domain']=$1
          shift
        else
          printf "invalid argument: %s\n" "$key" >&2
          exit 1
        fi

        ;;

    esac
  done

  # :command.required_args_filter
  if [[ -z ${args['domain']+x} ]]; then
    printf "missing required argument: DOMAIN\nusage: cybermigrate migrate DOMAIN [OPTIONS]\n" >&2

    exit 1
  fi

  # :command.default_assignments
  [[ -n ${args['--package']:-} ]] || args['--package']="Default"
  [[ -n ${args['--owner']:-} ]] || args['--owner']="admin"
  [[ -n ${args['--git-branch']:-} ]] || args['--git-branch']="main"

}

